# ─── Database ────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5436
POSTGRES_USER=concord
POSTGRES_PASSWORD=concord
POSTGRES_DB=concord

# ─── Redis ───────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6380

# ─── Anthropic / Claude ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6
ANTHROPIC_FAST_MODEL=claude-haiku-4-5-20251001

# ─── NestJS API ──────────────────────────────────────────────────────
API_PORT=3001
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
NODE_ENV=development

# ─── NextJS Web ──────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── Email (Gmail SMTP) ──────────────────────────────────────────────
GMAIL_USER=youraddress@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
GMAIL_FROM="Concord <youraddress@gmail.com>"

# ─── Firebase Cloud Messaging (server) ───────────────────────────────
FIREBASE_PROJECT_ID=concord-xxxxx
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@concord-xxxxx.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Firebase (web client) ───────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=concord-xxxxx.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=concord-xxxxx
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=
