# ─── Database ────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5436
POSTGRES_USER=concord
POSTGRES_PASSWORD=concord
POSTGRES_DB=concord

# ─── Supabase (Storage for avatars) ───────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...  # Settings → API → service_role key (keep secret)

# ─── Redis ───────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6380

# ─── Anthropic / Claude ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6
ANTHROPIC_FAST_MODEL=claude-haiku-4-5-20251001

# ─── NestJS API ──────────────────────────────────────────────────────
API_PORT=3001
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
NODE_ENV=development

# ─── NextJS Web ──────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
WEB_BASE_URL=http://localhost:3000   # URL dùng để build link trong email (invite, reset password)
NEXTAUTH_SECRET=change-me
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── Email (SendGrid HTTP API) ───────────────────────────────────────
SENDGRID_API_KEY=SG.xxx
SENDGRID_FROM="Concord <youraddress@gmail.com>"   # phải verify ở SendGrid → Sender Authentication → Single Sender
